{
  "manifest_version": 3,
  "name": "NyviaNexus",
  "version": "1.0.8",
  "action": {
    "default_popup": "index.html"
  },
  "options_page": "dashboard.html",
  "background": {
    "service_worker": "src/features/background/main.ts",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "windows",
    "storage",
    "unlimitedStorage",
    "scripting",
    "favicon",
    "alarms",
    "contextMenus"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Åbn NyviaNexus switcher"
    }
  },
  "incognito": "spanning",
  "host_permissions": ["<all_urls>"]
}
